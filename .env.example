# --- required ---
ELEVENLABS_API_KEY=sk_your_key
ELEVENLABS_AGENT_ID=agent_your_agent
WORKER_SHARED_SECRET=shared-secret-from-standin-pairing

# --- listener ---
#PORT=8080
#BIND=0.0.0.0
# Native TLS (wss). Leave unset when a tunnel/ingress terminates TLS for you.
#TLS_CERT_PATH=/path/cert.pem
#TLS_KEY_PATH=/path/key.pem

# --- call governor ---
#MAX_CALL_MINUTES=10
#EL_TTS_VOICE_ID=voice_id_for_deterministic_goodbye
#EL_TTS_MODEL_ID=eleven_turbo_v2_5
#GOODBYE_TEXT=I'm sorry, we've reached the time limit for this call. Thank you for calling, goodbye!
#GOODBYE_GRACE_MS=8000

# --- ElevenLabs options ---
#EL_HOST=api.elevenlabs.io
#EL_ENVIRONMENT=
#EL_AGENT_BRANCH_ID=
#EL_FIRST_MESSAGE=You are talking to an AI assistant.

# --- vision (the `look` client tool) ---
#VISION_API_URL=https://api.openai.com/v1/chat/completions
#VISION_API_KEY=sk-...
#VISION_MODEL=gpt-4o-mini

# --- hardening ---
#HMAC_FRESHNESS_MS=60000
#MAX_CONNECTIONS=64
#MAX_CONNECTIONS_PER_IP=
#PRE_START_TIMEOUT_MS=10000
#WORKER_IDLE_TIMEOUT_MS=90000
#TRUST_PROXY_XFF=false

# --- logging ---
#LOG_LEVEL=info
#LOG_TRANSCRIPTS=false
